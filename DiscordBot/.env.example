# Required
DISCORD_TOKEN=your_bot_token_here

# Optional: restrict slash-command registration to one guild (faster for development).
# Remove or leave blank to register commands globally.
DISCORD_GUILD_ID=

# Role name (or ID) whose members can use /faq add/edit/remove.
# Defaults to "Staff" if unset.
STAFF_ROLE=Staff

# GitHub webhook server port
WEBHOOK_PORT=8080

# Channel ID where GitHub webhook events are posted
GITHOOK_CHANNEL=

# Algolia DocSearch credentials (public read-only keys from ficsit.app docs)
ALGOLIA_APP_ID=2FDCZBLZ1A
ALGOLIA_API_KEY=28531804beda52a04275ecd964db429d

# Default GitHub repo for issue auto-linking (e.g. owner/repo)
GITHUB_REPO=
