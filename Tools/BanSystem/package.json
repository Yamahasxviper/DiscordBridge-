{
  "name": "satisfactory-ban-system",
  "version": "1.0.0",
  "description": "Standalone ban management service for Satisfactory Dedicated Server",
  "main": "dist/index.js",
  "bin": {
    "banctl": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-sqlite --no-warnings=ExperimentalWarning dist/index.js start",
    "dev": "node --experimental-sqlite --import ts-node/esm src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
